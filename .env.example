# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control.

# Telegram API credentials (from https://my.telegram.org)
API_ID=123456
API_HASH=abcdef1234567890abcdef1234567890

# Bot token from @BotFather
BOT_TOKEN=123456789:AAFxxxxxxxxxxxxxxxx

# Secret code new users must supply with /start to register
SECRET_INVITE_CODE=my-secret-code

# Telegram channel username or numeric ID to listen to
TARGET_CHANNEL=@channel_username
