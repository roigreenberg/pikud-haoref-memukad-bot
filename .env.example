# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control.

# Telegram API credentials (from https://my.telegram.org)
API_ID=123456
API_HASH=abcdef1234567890abcdef1234567890

# Bot token from @BotFather
BOT_TOKEN=123456789:AAFxxxxxxxxxxxxxxxx

# Secret code new users must supply with /start to register
SECRET_INVITE_CODE=my-secret-code

# Target Telegram channel username or numeric ID to listen to
TARGET_CHANNEL=@channel_username

# (Optional) Telethon StringSession for the listener client.
# When set, no .session file is needed — ideal for cloud/serverless deployments.
# Leave blank on first run; the session string will be printed to the console
# after you authenticate, so you can copy it here for subsequent runs.
SESSION_STRING=
